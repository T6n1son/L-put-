#!/bin/bash
# ================================================================
#  Tuuma ja tüüpteekide turvafunktsioonide kontrollskript
#  Kontrollib: ASLR, NX, RELRO, PIE, Stack Canary, FORTIFY,
#              RPATH, AppArmor/SELinux, Seccomp, sysctl
# ================================================================
 
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
 
ok()    { echo -e "    ${GREEN}✓${NC}  $*"; }
fail()  { echo -e "    ${RED}✗${NC}  $*"; }
warn()  { echo -e "    ${YELLOW}!${NC}  $*"; }
info()  { echo -e "    ${CYAN}→${NC}  ${DIM}$*${NC}"; }
header(){ echo -e "\n${BOLD}┌─────────────────────────────────────────────────┐${NC}"; \
          printf "${BOLD}│  %-47s │${NC}\n" "$1"; \
          echo -e "${BOLD}└─────────────────────────────────────────────────┘${NC}"; }
sub()   { echo -e "\n  ${BOLD}▸ $*${NC}"; }
 
SCORE_OK=0; SCORE_FAIL=0; SCORE_WARN=0
 
# ================================================================
#  LOGIMINE
# ================================================================
LOG_FILE="/var/log/turvacheck.log"
 
# Kui /var/log pole kirjutatav (mitte root), pane logi kodukausta
if [ ! -w /var/log ] 2>/dev/null; then
    LOG_FILE="$HOME/turvacheck.log"
fi
 
# Abifunktsioon: kirjutab logi ilma värvikoode ja erimärkideta
log() {
    local level="$1"   # OK | WARN | FAIL | INFO
    local category="$2"  # nt ASLR, NX, RELRO ...
    local message="$3"
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    printf "[%s] [%-4s] [%-20s] %s\n" "$ts" "$level" "$category" "$message" >> "$LOG_FILE"
}
 
# Tühista eelmine seansi logi ja kirjuta päis
{
    echo "================================================================"
    echo " TURVACHECK — $(uname -r) — $(date '+%Y-%m-%d %H:%M:%S')"
    echo " Süsteem: $(hostname)"
    echo "================================================================"
} >> "$LOG_FILE"
 
# ================================================================
#  Loendurid koos logimisega
# ================================================================
chk_ok() {
    ok "$@"
    ((SCORE_OK++))
}
chk_fail() {
    fail "$@"
    ((SCORE_FAIL++))
}
chk_warn() {
    warn "$@"
    ((SCORE_WARN++))
}
 
# Loendurid + logi korraga
lok()   { chk_ok   "$2"; log "OK"   "$1" "$2"; }
lfail() { chk_fail "$2"; log "FAIL" "$1" "$2"; }
lwarn() { chk_warn "$2"; log "WARN" "$1" "$2"; }
 
echo -e "\n${BOLD}╔══════════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║    TUUMA & TÜÜPTEEKIDE TURVAFUNKTSIOONID        ║${NC}"
echo -e "${BOLD}║    Süsteem: $(uname -r | cut -c1-20) $(date '+%Y-%m-%d %H:%M')    ║${NC}"
echo -e "${BOLD}╚══════════════════════════════════════════════════╝${NC}"
 
info "Logi salvestatakse: $LOG_FILE"
 
# ================================================================
header "1. TUUMA (KERNEL) TURVASEADED — sysctl"
# ================================================================
 
sysctl_check() {
    local key="$1" good="$2" label="$3" tip="$4"
    local val
    val=$(sysctl -n "$key" 2>/dev/null)
    if [ $? -ne 0 ]; then
        lwarn "SYSCTL/$key" "$label ($key): puudub/piiratud keskkond"
        return
    fi
    if [ "$val" = "$good" ]; then
        lok "SYSCTL/$key" "$label = $val"
    else
        lfail "SYSCTL/$key" "$label = $val (soovitav: $good)"
        [ -n "$tip" ] && info "Paranda: sysctl -w $key=$good"
    fi
}
 
sub "Mälu juhuslikustamine"
sysctl_check kernel.randomize_va_space 2 "ASLR" \
    "echo 2 > /proc/sys/kernel/randomize_va_space"
 
sub "Kerneli logi ja sümbolite kaitse"
sysctl_check kernel.dmesg_restrict     1 "dmesg_restrict (dmesg piiratud)"
sysctl_check kernel.kptr_restrict      2 "kptr_restrict (kerneli aadressid peidetud)"
 
sub "Protsesside jälgimine (ptrace)"
val=$(sysctl -n kernel.yama.ptrace_scope 2>/dev/null)
if [ -z "$val" ]; then
    lwarn "SYSCTL/ptrace_scope" "kernel.yama.ptrace_scope: puudub (Yama LSM pole laetud)"
else
    case "$val" in
        0) lfail "SYSCTL/ptrace_scope" "ptrace_scope = 0 (igaüks saab jälgida)" ;;
        1) lok   "SYSCTL/ptrace_scope" "ptrace_scope = 1 (ainult vanem-protsess)" ;;
        2) lok   "SYSCTL/ptrace_scope" "ptrace_scope = 2 (ainult root)" ;;
        3) lok   "SYSCTL/ptrace_scope" "ptrace_scope = 3 (ptrace keelatud)" ;;
    esac
fi
 
sub "BPF ja jõudlusmõõtmine"
sysctl_check kernel.perf_event_paranoid       3 "perf_event_paranoid"
sysctl_check kernel.unprivileged_bpf_disabled 1 "unprivileged_bpf_disabled"
sysctl_check net.core.bpf_jit_harden         2 "bpf_jit_harden"
 
sub "Failisüsteemi kaitse"
sysctl_check fs.protected_hardlinks  1 "protected_hardlinks"
sysctl_check fs.protected_symlinks   1 "protected_symlinks"
sysctl_check fs.suid_dumpable        0 "suid_dumpable (core dump piiratud)"
 
# ================================================================
header "2. CPU RIISTVARA TURVAFUNKTSIOONID"
# ================================================================
 
for flag in nx smep smap; do
    if grep -qw "$flag" /proc/cpuinfo 2>/dev/null; then
        case $flag in
            nx)   lok "CPU/NX"   "NX/XD bitt: CPU toetab mälu täitmiskaitstet" ;;
            smep) lok "CPU/SMEP" "SMEP: kernel ei täida kasutajaruumi koodi" ;;
            smap) lok "CPU/SMAP" "SMAP: kernel ei loe kasutajaruumi mälu" ;;
        esac
    else
        lfail "CPU/${flag^^}" "${flag^^}: puudub"
    fi
done
 
# ================================================================
header "3. TÜÜPTEEKIDE KAITSEFUNKTSIOONID (binaarid)"
# ================================================================
 
BINS=()
for b in /bin/bash /bin/ls /usr/bin/sudo /usr/bin/python3 \
         /usr/bin/perl /usr/sbin/sshd /usr/bin/ssh \
         /usr/bin/passwd /usr/bin/gpg; do
    [ -f "$b" ] && BINS+=("$b")
done
 
if ! command -v readelf &>/dev/null; then
    lwarn "BINAARID" "readelf pole installitud — binaaride kontroll vahele jäetud"
    warn "Installi: apt install binutils"
else
    echo ""
    printf "  %-22s %-10s %-8s %-8s %-8s %-8s %-8s\n" \
        "Binaar" "RELRO" "Canary" "PIE" "NX" "FORTIFY" "RPATH"
    echo "  $(printf '%.0s─' {1..80})"
 
    for bin in "${BINS[@]}"; do
        name=$(basename "$bin")
 
        # RELRO
        relro_seg=$(readelf -l "$bin" 2>/dev/null | grep GNU_RELRO)
        bind_now=$(readelf -d  "$bin" 2>/dev/null | grep BIND_NOW)
        if [ -n "$relro_seg" ] && [ -n "$bind_now" ]; then
            relro="${GREEN}Full${NC}";    log "OK"   "RELRO/$name"  "Full RELRO";    ((SCORE_OK++))
        elif [ -n "$relro_seg" ]; then
            relro="${YELLOW}Partial${NC}"; log "WARN" "RELRO/$name" "Partial RELRO"; ((SCORE_WARN++))
        else
            relro="${RED}Puudub${NC}";   log "FAIL" "RELRO/$name"  "RELRO puudub";  ((SCORE_FAIL++))
        fi
 
        # Stack Canary
        if readelf -s "$bin" 2>/dev/null | grep -q '__stack_chk_fail'; then
            canary="${GREEN}Jah${NC}"; log "OK"   "CANARY/$name" "Stack Canary olemas"; ((SCORE_OK++))
        else
            canary="${RED}Ei${NC}";   log "FAIL" "CANARY/$name" "Stack Canary puudub"; ((SCORE_FAIL++))
        fi
 
        # PIE
        etype=$(readelf -h "$bin" 2>/dev/null | awk '/Type:/{print $2}')
        if [ "$etype" = "DYN" ]; then
            pie="${GREEN}Jah${NC}"; log "OK"   "PIE/$name" "PIE lubatud (DYN)"; ((SCORE_OK++))
        else
            pie="${RED}Ei${NC}";   log "FAIL" "PIE/$name" "PIE puudub (tüüp: $etype)"; ((SCORE_FAIL++))
        fi
 
        # NX
        nx_flag=$(readelf -l "$bin" 2>/dev/null | awk '/GNU_STACK/{print $NF}')
        if [ "$nx_flag" = "RWE" ]; then
            nx="${RED}Ei${NC}";   log "FAIL" "NX/$name" "NX puudub (stack on täidetav)"; ((SCORE_FAIL++))
        else
            nx="${GREEN}Jah${NC}"; log "OK"  "NX/$name" "NX lubatud (GNU_STACK: $nx_flag)"; ((SCORE_OK++))
        fi
 
        # FORTIFY
        if readelf -s "$bin" 2>/dev/null | grep -q '__.*_chk'; then
            fortify="${GREEN}Jah${NC}"; log "OK"   "FORTIFY/$name" "FORTIFY aktiivsed"; ((SCORE_OK++))
        else
            fortify="${RED}Ei${NC}";   log "FAIL" "FORTIFY/$name" "FORTIFY puudub";    ((SCORE_FAIL++))
        fi
 
        # RPATH (ohtlik)
        rpath=$(readelf -d "$bin" 2>/dev/null | grep -i 'rpath\|runpath')
        if [ -n "$rpath" ]; then
            rpath_s="${RED}OHTLIK${NC}"; log "FAIL" "RPATH/$name" "RPATH/RUNPATH olemas — ohtlik: $rpath"; ((SCORE_FAIL++))
        else
            rpath_s="${GREEN}Ei${NC}";   log "OK"   "RPATH/$name" "RPATH puudub — ok"; ((SCORE_OK++))
        fi
 
        printf "  %-22s " "$name"
        printf "%-20b %-18b %-18b %-18b %-18b %-18b\n" \
            "$relro" "$canary" "$pie" "$nx" "$fortify" "$rpath_s"
    done
fi
 
# ================================================================
header "4. LIBC TURVAFUNKTSIOONID"
# ================================================================
 
libc=$(ldconfig -p 2>/dev/null | awk '/libc\.so\.6/{print $NF; exit}')
if [ -z "$libc" ]; then
    lwarn "LIBC" "libc.so.6 ei leitud"
else
    info "Asukoht: $libc"
    log "INFO" "LIBC" "Asukoht: $libc"
 
    nx_libc=$(readelf -l "$libc" 2>/dev/null | awk '/GNU_STACK/{print $NF}')
    if [ "$nx_libc" != "RWE" ]; then
        lok "LIBC/NX"    "libc NX: sees (GNU_STACK: $nx_libc)"
    else
        lfail "LIBC/NX"  "libc NX: väljas"
    fi
 
    relro_libc=$(readelf -l "$libc" 2>/dev/null | grep GNU_RELRO)
    if [ -n "$relro_libc" ]; then
        lok "LIBC/RELRO"  "libc RELRO: olemas"
    else
        lfail "LIBC/RELRO" "libc RELRO: puudub"
    fi
 
    etype_libc=$(readelf -h "$libc" 2>/dev/null | awk '/Type:/{print $2}')
    if [ "$etype_libc" = "DYN" ]; then
        lok "LIBC/PIE"   "libc PIE/PIC: jah (DYN)"
    else
        lwarn "LIBC/PIE"  "libc tüüp: $etype_libc"
    fi
 
    fortify_count=$(readelf -s "$libc" 2>/dev/null | grep -c '__.*_chk')
    if [ "$fortify_count" -gt 0 ]; then
        lok "LIBC/FORTIFY"  "libc FORTIFY: $fortify_count kaitstud funktsiooni"
    else
        lfail "LIBC/FORTIFY" "libc FORTIFY: funktsioonid puuduvad"
    fi
fi
 
# ================================================================
header "5. TÄIENDAVAD TURVAMEHHANISMID"
# ================================================================
 
sub "AppArmor"
if command -v aa-status &>/dev/null; then
    profiles=$(aa-status 2>/dev/null | grep 'profiles are loaded' | awk '{print $1}')
    enforced=$(aa-status 2>/dev/null | grep 'profiles are in enforce' | awk '{print $1}')
    if [ -n "$profiles" ] && [ "$profiles" -gt 0 ]; then
        lok "APPARMOR" "AppArmor: $profiles profiili laetud, $enforced enforce-režiimis"
    else
        lwarn "APPARMOR" "AppArmor: aktiivne aga profiilid puuduvad"
    fi
elif [ -d /sys/kernel/security/apparmor ]; then
    lwarn "APPARMOR" "AppArmor: tuumamoodul laetud, aa-status pole installitud"
else
    lwarn "APPARMOR" "AppArmor: pole aktiivne"
fi
 
sub "SELinux"
if command -v getenforce &>/dev/null; then
    se=$(getenforce 2>/dev/null)
    case "$se" in
        Enforcing)  lok   "SELINUX" "SELinux: Enforcing" ;;
        Permissive) lwarn "SELINUX" "SELinux: Permissive (ainult logib)" ;;
        Disabled)   lfail "SELINUX" "SELinux: Disabled" ;;
    esac
else
    log "INFO" "SELINUX" "SELinux: pole installitud"
    warn "SELinux: pole installitud"
fi
 
sub "Seccomp (praegune protsess)"
sec=$(grep -i 'Seccomp:' /proc/$$/status 2>/dev/null | awk '{print $2}')
case "$sec" in
    0) lwarn "SECCOMP" "Seccomp: väljas (praegusel protsessil)" ;;
    1) lok   "SECCOMP" "Seccomp: strict režiim" ;;
    2) lok   "SECCOMP" "Seccomp: filter režiim (BPF)" ;;
    *) lwarn "SECCOMP" "Seccomp: teadmata ($sec)" ;;
esac
 
# ================================================================
header "KOKKUVÕTE"
# ================================================================
 
TOTAL=$((SCORE_OK + SCORE_FAIL + SCORE_WARN))
PCT=0
[ $TOTAL -gt 0 ] && PCT=$(( SCORE_OK * 100 / TOTAL ))
 
echo ""
echo -e "  ${GREEN}✓ Korras:    $SCORE_OK${NC}"
echo -e "  ${YELLOW}! Hoiatus:   $SCORE_WARN${NC}"
echo -e "  ${RED}✗ Probleem:  $SCORE_FAIL${NC}"
echo -e "  ─────────────────────"
echo -e "  ${BOLD}Tulemus: $PCT% ($SCORE_OK/$TOTAL)${NC}"
echo ""
 
if   [ $PCT -ge 80 ]; then echo -e "  ${GREEN}${BOLD}► Süsteem on hästi kaitstud.${NC}"
elif [ $PCT -ge 50 ]; then echo -e "  ${YELLOW}${BOLD}► Süsteemil on turvavõimalusi parandada.${NC}"
else                        echo -e "  ${RED}${BOLD}► Süsteem vajab kiiret turvakonfiguratsiooni!${NC}"
fi
 
# Kokkuvõte logi lõppu
{
    echo "----------------------------------------------------------------"
    printf "TULEMUS: %d%% | OK: %d | WARN: %d | FAIL: %d | KOKKU: %d\n" \
        "$PCT" "$SCORE_OK" "$SCORE_WARN" "$SCORE_FAIL" "$TOTAL"
    if   [ $PCT -ge 80 ]; then echo "HINNANG: Hästi kaitstud"
    elif [ $PCT -ge 50 ]; then echo "HINNANG: Turvavõimalusi parandada"
    else                        echo "HINNANG: Vajab kiiret sekkumist!"
    fi
    echo "================================================================"
    echo ""
} >> "$LOG_FILE"
 
echo ""
echo -e "  ${CYAN}→${NC} ${BOLD}Logi salvestatud: $LOG_FILE${NC}"
echo ""
echo -e "  ${DIM}Soovitused:${NC}"
echo -e "  ${CYAN}→${NC} ${DIM}ASLR:    sysctl -w kernel.randomize_va_space=2${NC}"
echo -e "  ${CYAN}→${NC} ${DIM}Kompileeri: gcc -fstack-protector-strong -D_FORTIFY_SOURCE=2 -pie -fPIE -Wl,-z,relro,-z,now${NC}"
echo ""
 
